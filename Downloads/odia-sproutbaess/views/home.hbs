        <div class="stat-num">12k<span class="stat-plus">+</span></div>
        <div class="stat-label">ଖୁସି ଗ୍ରାହକ · Happy Customers</div>
      </div>
    </div>
  </div>
</section>

<!-- NEWSLETTER -->
<section class="newsletter">
  <p class="section-eyebrow">Sambada · ସମ୍ବାଦ</p>
  <h2 class="newsletter-title">Stay connected with Odisha</h2>
  <p class="newsletter-sub">Seasonal pithas, temple festivals, new arrivals — delivered to your inbox.</p>
  <form class="newsletter-form" onsubmit="handleNewsletter(event)">
    <input type="email" placeholder="Your email address · ଆପଣଙ୍କ ଇମେଲ" required />
    <button type="submit" class="btn-primary">Subscribe · ସଦସ୍ୟ ହୁଅନ୍ତୁ</button>
  </form>
</section>
