<!-- STORY BAND -->
<section class="story-band">
  <div class="story-inner">
    <div class="story-text">
      <p class="section-eyebrow" style="color: var(--turmeric-light)">Amara Kahani · ଆମର କାହାଣୀ</p>
      <h2 class="story-title">Preserving flavours that <em>grandmothers</em> still remember</h2>
      <p class="story-body">We work directly with artisan families across 18 districts of Odisha — from the coastal kitchens of Puri to the tribal heartland of Koraput. No middlemen, no factories. Just recipes passed down through generations, packed with love.</p>
      <a href="/our-story" class="btn-outline-light">Read Our Story →</a>
    </div>
    <div class="story-stats">
      <div class="stat-item">
        <div class="stat-num">40<span class="stat-plus">+</span></div>
        <div class="stat-label">ପରିବାର · Artisan Families</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">18</div>
